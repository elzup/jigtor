{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "title": "Device name",
      "description": "Unique device identifier (alphanumeric).",
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9]+$"
    },
    "mode": {
      "type": "string",
      "enum": ["idle", "active", "sleep"],
      "default": "idle"
    },
    "ratio": {
      "type": "number",
      "title": "Sample ratio",
      "description": "Fraction of events to sample (0–1).",
      "minimum": 0,
      "maximum": 1,
      "default": 0.5
    },
    "retries": {
      "type": "integer",
      "title": "Retry limit",
      "description": "Max retry attempts before giving up.",
      "minimum": 0,
      "maximum": 10,
      "default": 3
    },
    "telemetry": {
      "type": "object",
      "title": "Telemetry",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "intervalSec": { "type": "number", "minimum": 0.5 }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
