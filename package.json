{
  "name": "jigtor",
  "version": "0.1.1",
  "description": "Local-first, schema-driven config.json editor",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "portless run --name jigtor vite",
    "dev:tauri": "vite --port 5173 --strictPort",
    "tauri": "tauri",
    "build": "tsc && vite build && node tools/inline-dist.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "ceg": "node tools/ceg.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "ajv": "^8.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "fast-check": "^3.23.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
  }
}
